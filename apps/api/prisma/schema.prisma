// Prisma schema — Lubin Investment
// docs: https://pris.ly/d/prisma-schema

generator client {
  provider      = "prisma-client-js"
  // native       → macOS local dev (Darwin arm64/x64)
  // rhel-openssl-3.0.x → Vercel serverless runtime (Amazon Linux 2023, OpenSSL 3)
  // Sans ce target, Prisma plante au cold start : "Could not load engine"
  binaryTargets = ["native", "rhel-openssl-3.0.x"]
}

datasource db {
  provider  = "postgresql"
  // url       = connexion POOLÉE (PgBouncer) → runtime de l'app (Vercel lambda).
  url       = env("DATABASE_URL")
  // directUrl = connexion DIRECTE (non poolée) → migrations uniquement.
  // `prisma migrate deploy` pose un advisory lock niveau session : impossible via le pooler
  // (chaque requête part sur un backend différent → lock perdu → timeout P1002). La connexion
  // directe (même host SANS `-pooler`) règle ça. Cf. doc Neon « Connect from Prisma ».
  directUrl = env("DIRECT_URL")
}

/// Utilisateur — auth email/password locale (pas de social pour le moment).
/// Le passwordHash est un bcrypt cost 12. L'email est normalisé en lowercase à l'insert.
model User {
  id           String   @id @default(cuid())
  email        String   @unique
  passwordHash String
  /// Prénom / nom saisis à l'inscription. Nullable : les comptes créés avant cette
  /// colonne n'en ont pas (les initiales du menu sont alors dérivées de l'email).
  firstName    String?
  lastName     String?
  /// Email vérifié via le lien envoyé à l'inscription. Non bloquant (signal de confiance).
  emailVerified Boolean @default(false)
  createdAt    DateTime @default(now())

  // ─── Abonnement Stripe ─────────────────────────────────────────────────────
  /// Customer ID Stripe — créé au premier checkout, réutilisé pour le portail
  /// de gestion d'abonnement. Null tant que l'utilisateur n'a jamais tenté un
  /// paiement.
  stripeCustomerId String? @unique
  /// Statut d'abonnement : `free` (défaut), `active`, `past_due`, `canceled`,
  /// `unpaid`, `incomplete`, `incomplete_expired`. Mis à jour par le webhook
  /// Stripe (customer.subscription.created/updated/deleted).
  subscriptionStatus String @default("free")
  /// Plan en cours : `monthly` ou `yearly` (null si free).
  subscriptionPlan   String?
  /// Fin de la période payée en cours — l'accès Pro reste actif jusqu'à cette
  /// date même si l'utilisateur a déjà annulé (renouvellement off). Source de
  /// vérité pour le gate `isPro` côté API.
  subscriptionCurrentPeriodEnd DateTime?
  /// Stripe subscription ID — utile pour les webhooks et le portail.
  stripeSubscriptionId String? @unique

  // ─── Quota d'analyses gratuites ────────────────────────────────────────────
  /// Nombre d'analyses faites aujourd'hui (UTC). Reset par dailyAnalysisResetAt.
  /// Non utilisé pour les utilisateurs Pro (= illimité).
  dailyAnalysisCount Int      @default(0)
  /// Date du début de la fenêtre 24h en cours. Le compteur reset quand un
  /// nouvel appel arrive après que 24h se soient écoulées depuis cette date.
  dailyAnalysisResetAt DateTime @default(now())

  watchlist WatchlistEntry[]
  portfolio PortfolioPosition[]
}

/// Position du portefeuille personnel suivi (page « Stratégie portefeuille »). Achats et ventes
/// saisis manuellement par le propriétaire → alimente le suivi forward « Ma sélection » comparé
/// au S&P 500 et au panier value+momentum. Position ouverte tant que sellDate est null.
model PortfolioPosition {
  id        String   @id @default(cuid())
  userId    String
  ticker    String
  /// Date d'achat (YYYY-MM-DD).
  buyDate   String
  /// Prix d'achat (fill réel saisi par l'utilisateur).
  buyPrice  Float
  /// Date de vente (YYYY-MM-DD) ; null = position toujours ouverte.
  sellDate  String?
  /// Prix de vente ; null tant que la position est ouverte.
  sellPrice Float?
  /// Thèse / note libre (optionnel).
  note      String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

/// Analyse qualitative du BUSINESS MODEL — cache À VIE (immutable une fois généré).
///
/// Pourquoi immutable : le business model d'une boîte évolue à l'échelle des années
/// (refonte produit, pivot stratégique), pas des semaines. Et chaque génération coûte
/// un appel GPT-4o-search-preview (~$0.05-0.10). On freeze pour éviter de cramer la clé
/// API à chaque rechargement. Si vraiment il faut regénérer (rare cas), suppression
/// manuelle de la ligne DB.
///
/// verdictDirect = la 1-2 phrases punchy affichée en haut du ScoreCard. Vit avec
/// business car concerne le nature de la société.
model BusinessAnalysis {
  ticker        String
  /// Langue de l'analyse (fr/en/es) — cache séparé par langue.
  lang          String   @default("fr")
  /// JSON contenant business: Criterion[] (10 critères)
  business      Json
  /// 1-2 phrases punchy
  verdictDirect String
  /// « Part de marché du moment » — un Criterion enrichi (part estimée + tendance + concurrents
  /// + source), généré avec l'analyse business. Affiché dans la partie quali mais HORS notation.
  /// Nullable : les analyses générées avant cette feature ne l'ont pas (régénération pour l'obtenir).
  marketShare   Json?
  createdAt     DateTime @default(now())

  @@id([ticker, lang])
}

/// Analyse qualitative du MANAGEMENT — RAFRAÎCHISSABLE manuellement.
///
/// Le management peut changer (départ CEO/CFO, scandale, board reshuffle) à des
/// échelles plus courtes que le business. L'utilisateur déclenche un refresh via
/// bouton dédié. Pas de TTL automatique — l'utilisateur sait quand il y a un changement.
model ManagementAnalysis {
  ticker     String
  /// Langue de l'analyse (fr/en/es) — cache séparé par langue.
  lang       String   @default("fr")
  /// JSON contenant management: Criterion[] (5 critères)
  management Json
  updatedAt  DateTime @default(now()) @updatedAt

  @@id([ticker, lang])
}

/// Snapshot Resilience publie, calcule hors du chemin de lecture d'Analyze.
model ResilienceAnalysis {
  ticker        String
  version       String
  status        String
  analysis      Json?
  researchDossier String?
  researchHash  String?
  asOf          DateTime?
  attempts      Int      @default(0)
  lastError     String?
  lastAttemptAt DateTime?
  createdAt     DateTime @default(now())
  refreshedAt   DateTime @default(now())

  @@id([ticker, version])
  @@index([version, status, refreshedAt])
}

model ResilienceAnalysisHistory {
  id              String   @id @default(cuid())
  ticker          String
  version         String
  asOf            DateTime
  analysis        Json
  researchDossier String?
  researchHash    String?
  diff            Json?
  createdAt       DateTime @default(now())

  @@unique([ticker, version, asOf])
  @@index([ticker, version, asOf])
}

/// Cache GLOBAL par ticker du résultat de l'analyse quant.
///
/// Source unique de vérité partagée entre /api/analyze et /api/watchlist :
/// quand l'utilisateur clique sur "Analyser" pour un ticker, le résultat (score,
/// chiffres, métriques) est écrit ici. La watchlist lit DIRECTEMENT depuis cette
/// table — elle ne recompute jamais. Conséquence : impossible de diverger.
///
/// Global (pas per-user) car les fundamentaux sont universels.
model TickerQuantSnapshot {
  ticker      String   @id
  snapshot    Json
  refreshedAt DateTime @default(now())

  @@index([refreshedAt])
}

/// Cache PERSISTANT des séries temporelles des graphiques détaillés (histogramme par
/// métrique, P/FCF, Cash ROCE). Persisté en DB (et non en mémoire par instance) → partagé
/// entre toutes les instances de lambda, survit aux cold starts. TTL calé sur le prochain
/// earnings (champ expiresAt) → invalidation post-résultats automatique.
/// Clé = `ticker|metric|freq|years`.
model ChartCache {
  key            String   @id
  points         Json
  source         String
  servedFreq     String?
  annualFallback Boolean?
  expiresAt      DateTime
  storedAt       DateTime @default(now())

  @@index([expiresAt])
}

/// Store PERSISTANT et CANONIQUE des séries trimestrielles brutes de fondamentaux
/// (revenue, cfo, capex, sbc, shares, netIncome, operatingIncome, totalDebt, cash…).
/// = sortie de getReportedTimeseries AVANT ajustement splits : dé-cumulée (YTD→trimestre)
/// + trous comblés via SEC EDGAR. APPEND-ONLY : on n'ajoute que les trimestres absents
/// (nouveaux résultats OU trous anciens nouvellement comblés), jamais d'écrasement d'une
/// valeur existante → stabilité point-in-time + zéro re-fetch entre deux earnings.
/// L'ajustement splits (shares uniquement) est appliqué À LA LECTURE pour qu'un futur split
/// ré-aligne tout l'historique sans figer une base obsolète.
/// `expiresAt` = lastEnd + ~120j (plancher re-check 14j) → re-fetch quand un nouveau trimestre
/// est déposé. Clé = (ticker, metric). Bypass total en replay backtest (non point-in-time).
model FundamentalsSeries {
  ticker    String
  metric    String
  /// TimeseriesPoint[] {date, value} complet, trié ASC, dé-cumulé + EDGAR mergé, PRÉ-split.
  points    Json
  /// 'finnhub' | 'finnhub+edgar' | 'finnhub-empty' | 'yahoo' | 'yahoo-empty'
  source    String
  /// 'quarterly' (US, Finnhub+EDGAR) | 'annual' (non-US, Yahoo). Observabilité — la clé reste
  /// (ticker, metric) car les noms de métriques ne collisionnent pas (revenue vs annualTotalRevenue).
  freq      String   @default("quarterly")
  /// Fin de la dernière période stockée (YYYY-MM-DD). Null si série vide.
  lastEnd   String?
  expiresAt DateTime
  builtAt   DateTime @default(now())

  @@id([ticker, metric])
  @@index([expiresAt])
}

/// Veille quantitative automatique ("screener"). Une ligne par ticker de l'univers.
/// La note /10 (quanti uniquement, jamais de GPT) est recalculée quand `nextEarningsDate`
/// est atteinte — le quantitatif ne bouge qu'aux résultats. Tant que la date est future,
/// le score reste en cache. Le détail complet vit dans TickerQuantSnapshot.
///
/// Couverture progressive : priority 0=US, 1=EU, 2=OTHER (le worker pioche dans cet ordre).
model ScreenerTicker {
  ticker             String    @id
  exchange           String?
  name               String?
  currency           String?
  region             String    @default("US")
  priority           Int       @default(0)
  /// pending | scored | nodata | error
  status             String    @default("pending")
  scoreChiffres      Int?
  scoreChiffresMax   Int?
  /// scoreChiffres / scoreChiffresMax — indexé pour le tri "meilleures notes"
  scoreRatio         Float?
  pfcfTTM            Float?
  /// Métadonnées d'affichage du screener
  sector             String?
  price              Float?
  /// Variation du jour en %
  dayChangePct       Float?
  /// Capitalisation boursière (prix × actions), figée au scoring. Devise locale du titre
  /// (approximation US-first, comme marketBeat). Null si prix ou nb d'actions indisponible.
  /// Alimente le filtre Small/Mid/Large cap du screener.
  marketCap          Float?
  /// Closes mensuels ~1 an pour la sparkline (number[])
  spark              Json?
  fundamentalsSource String?
  /// Date du prochain earnings (YYYY-MM-DD) — pilote le re-scoring
  nextEarningsDate   String?
  lastScoredAt       DateTime?
  attempts           Int       @default(0)
  /// Dernière fois que les séries de graphiques (ChartCache) ont été préremplies pour ce
  /// ticker. Null = jamais → la veille les comble progressivement (comme elle a scoré l'univers).
  chartsWarmedAt     DateTime?
  /// « Opportunité du moment » : P/FCF dans son décile bas historique (≤10) ET < 25.
  opportunity        Boolean   @default(false)
  /// Percentile actuel du P/FCF vs son historique (0-100). Null si indisponible.
  pfcfPercentile     Float?
  /// Seuil P/FCF du décile bas historique (valeur au 10e percentile), figé au scoring.
  /// Permet de RÉ-ÉVALUER l'opportunité EN LIVE (pfcf_live ≤ pfcfDecile10) avec juste le prix
  /// du jour, sans recharger toute la distribution. La distribution ne bouge qu'aux earnings.
  pfcfDecile10       Float?
  /// Dernière ré-évaluation LIVE du flag opportunity (au prix du jour). Pilote le throttle (~10 min).
  oppRefreshedAt     DateTime?
  updatedAt          DateTime  @updatedAt

  @@index([status, priority, lastScoredAt])
  @@index([scoreRatio])
  @@index([opportunity])
}

/// Watchlist par utilisateur. Un même ticker peut apparaître chez plusieurs users (différentes lignes).
/// Les champs `snapshot` + `refreshedAt` sont legacy — gardés pour backward-compat mais
/// plus utilisés depuis l'introduction de TickerQuantSnapshot (cache global).
model WatchlistEntry {
  id        Int      @id @default(autoincrement())
  userId    String
  ticker    String
  addedAt   DateTime @default(now())
  /// Snapshot du dernier refresh (P/FCF, score chiffres, etc.) — nullable au premier ajout
  snapshot  Json?
  /// Date du dernier rafraîchissement
  refreshedAt DateTime?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  /// Un user ne peut pas avoir le même ticker deux fois
  @@unique([userId, ticker])
  @@index([userId])
}
