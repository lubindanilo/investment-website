{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://lubin-investment.local/schemas/resilience-2033-adjudication.json",
  "$comment": "methodologyVersion: 2.9.1-pilot.21",
  "title": "Lubin Investment Resilience 2033 Adjudication",
  "type": "object",
  "additionalProperties": false,
  "required": ["scenarioYear", "criteria"],
  "properties": {
    "scenarioYear": { "const": 2033 },
    "criteria": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "future_control",
        "disruption_positioning",
        "future_dependencies",
        "structural_demand",
        "future_value_capture",
        "transition_capacity"
      ],
      "properties": {
        "future_control": { "$ref": "#/$defs/futureControl" },
        "disruption_positioning": { "$ref": "#/$defs/disruption" },
        "future_dependencies": { "$ref": "#/$defs/dependencies" },
        "structural_demand": { "$ref": "#/$defs/demand" },
        "future_value_capture": { "$ref": "#/$defs/valueCapture" },
        "transition_capacity": { "$ref": "#/$defs/transition" }
      }
    }
  },
  "$defs": {
    "triState": { "type": ["boolean", "null"] },
    "confidence": { "enum": ["high", "medium", "low"] },
    "common": {
      "type": "object",
      "required": ["reason", "adverseCase", "decisiveTrigger", "confidence"],
      "properties": {
        "reason": { "type": "string", "minLength": 1 },
        "adverseCase": { "type": "string", "minLength": 1 },
        "decisiveTrigger": { "type": "string", "minLength": 1 },
        "confidence": { "$ref": "#/$defs/confidence" }
      }
    },
    "futureControl": {
      "allOf": [
        { "$ref": "#/$defs/common" },
        {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "futureProjectionContract",
            "controlType", "controlStillNeeded", "companySpecific", "majorityCoreCoverage",
            "scarcitySurvivesAiChina", "replicableWithinFiveYears", "futureRentPaid",
            "systemBottleneck", "multipleIndependentControls"
            , "controlPortfolio"
          ],
          "properties": {
            "reason": true,
            "adverseCase": true,
            "decisiveTrigger": true,
            "confidence": true,
            "futureProjectionContract": { "const": true },
            "controlType": {
              "enum": [
                "scarce_asset", "regulated_right", "trusted_brand", "network_liquidity",
                "proprietary_stack_or_ip", "cost_supply_chain", "installed_base",
                "regulated_execution_capability", "none"
              ]
            },
            "controlStillNeeded": { "$ref": "#/$defs/triState" },
            "companySpecific": { "$ref": "#/$defs/triState" },
            "majorityCoreCoverage": { "$ref": "#/$defs/triState" },
            "scarcitySurvivesAiChina": { "$ref": "#/$defs/triState" },
            "replicableWithinFiveYears": { "$ref": "#/$defs/triState" },
            "futureRentPaid": { "$ref": "#/$defs/triState" },
            "systemBottleneck": { "$ref": "#/$defs/triState" },
            "multipleIndependentControls": { "$ref": "#/$defs/triState" },
            "rightsVisibilityThroughScenario": { "$ref": "#/$defs/triState" }
            , "controlPortfolio": { "$ref": "#/$defs/controlPortfolio" }
          }
        }
      ]
    },
    "portfolioControl": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "controlType", "coreSegment", "materialMinorityCoverage", "companySpecific",
        "futureRentPaid", "survivesAiChina", "independentFromOtherControls"
      ],
      "properties": {
        "controlType": {
          "enum": [
            "scarce_asset", "regulated_right", "trusted_brand", "network_liquidity",
            "proprietary_stack_or_ip", "cost_supply_chain", "installed_base",
            "regulated_execution_capability"
          ]
        },
        "coreSegment": { "type": "string", "minLength": 1 },
        "materialMinorityCoverage": { "$ref": "#/$defs/triState" },
        "companySpecific": { "$ref": "#/$defs/triState" },
        "futureRentPaid": { "$ref": "#/$defs/triState" },
        "survivesAiChina": { "$ref": "#/$defs/triState" },
        "independentFromOtherControls": { "$ref": "#/$defs/triState" }
      }
    },
    "controlPortfolio": {
      "type": "object",
      "additionalProperties": false,
      "required": ["applies", "nonOverlappingCombinedMajorityCoverage", "controls"],
      "properties": {
        "applies": { "$ref": "#/$defs/triState" },
        "nonOverlappingCombinedMajorityCoverage": { "$ref": "#/$defs/triState" },
        "controls": { "type": "array", "items": { "$ref": "#/$defs/portfolioControl" } }
      }
    },
    "force": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "force", "majorityCoreThreatPath", "technicalAndEconomicPath",
        "materialPressure", "materialDirectBenefit", "responseControlsOutcome", "benefitMechanism"
      ],
      "properties": {
        "force": { "enum": ["ai_agents", "automation_robotics", "china_engineering"] },
        "majorityCoreThreatPath": { "$ref": "#/$defs/triState" },
        "technicalAndEconomicPath": { "$ref": "#/$defs/triState" },
        "materialPressure": { "$ref": "#/$defs/triState" },
        "materialDirectBenefit": { "$ref": "#/$defs/triState" },
        "responseControlsOutcome": { "$ref": "#/$defs/triState" },
        "benefitMechanism": {
          "enum": [
            "none", "external_demand_expansion", "company_specific_control_strengthening",
            "company_specific_cost_or_capacity_advantage",
            "company_specific_value_capture_expansion", "unproven"
          ]
        }
      }
    },
    "disruption": {
      "allOf": [
        { "$ref": "#/$defs/common" },
        {
          "type": "object",
          "additionalProperties": false,
          "required": ["forces"],
          "properties": {
            "reason": true,
            "adverseCase": true,
            "decisiveTrigger": true,
            "confidence": true,
            "forces": {
              "type": "array",
              "minItems": 3,
              "maxItems": 3,
              "items": { "$ref": "#/$defs/force" }
            }
          }
        }
      ]
    },
    "dependency": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "name", "shockGroup", "material", "continuityImpact", "mitigation",
        "coreContinuityAtRisk"
      ],
      "properties": {
        "name": { "type": "string", "minLength": 1 },
        "shockGroup": { "type": "string", "minLength": 1 },
        "material": { "$ref": "#/$defs/triState" },
        "continuityImpact": {
          "enum": ["existential", "material_impairment", "non_core", "unproven"]
        },
        "mitigation": { "enum": ["strong", "medium", "none", "unproven"] },
        "coreContinuityAtRisk": { "$ref": "#/$defs/triState" }
      }
    },
    "dependencies": {
      "allOf": [
        { "$ref": "#/$defs/common" },
        {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "residualOnlyAssessment", "futureSeverityContract", "futureShockGroupContract",
            "coverageComplete", "clusters"
          ],
          "properties": {
            "reason": true,
            "adverseCase": true,
            "decisiveTrigger": true,
            "confidence": true,
            "residualOnlyAssessment": { "const": true },
            "futureSeverityContract": { "const": true },
            "futureShockGroupContract": { "const": true },
            "coverageComplete": { "$ref": "#/$defs/triState" },
            "clusters": { "type": "array", "items": { "$ref": "#/$defs/dependency" } }
          }
        }
      ]
    },
    "demand": {
      "allOf": [
        { "$ref": "#/$defs/common" },
        {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "futureCategoryTrend", "causalDirectness", "coreExposure",
            "netExpansionAfterSubstitution", "futureDriver"
          ],
          "properties": {
            "reason": true,
            "adverseCase": true,
            "decisiveTrigger": true,
            "confidence": true,
            "futureCategoryTrend": { "enum": ["rising", "stable", "declining", "unproven"] },
            "causalDirectness": { "enum": ["direct", "enabling", "indirect", "none", "unproven"] },
            "coreExposure": { "enum": ["majority", "material_minority", "limited", "unproven"] },
            "netExpansionAfterSubstitution": { "$ref": "#/$defs/triState" },
            "futureDriver": {
              "enum": [
                "ai_agents", "automation_robotics", "china_engineering", "demographics_social",
                "climate_resources", "regulation_infrastructure", "generic_market_forecast", "unproven"
              ]
            }
          }
        }
      ]
    },
    "marketplaceMechanics": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "applies", "fragmentedCounterparties", "companyOperatesMatchingAndExecution",
        "agentsRequireComparableCoverageOrLiquidity", "scaledAlternativeCanBypassMajorityBy2033"
      ],
      "properties": {
        "applies": { "$ref": "#/$defs/triState" },
        "fragmentedCounterparties": { "$ref": "#/$defs/triState" },
        "companyOperatesMatchingAndExecution": { "$ref": "#/$defs/triState" },
        "agentsRequireComparableCoverageOrLiquidity": { "$ref": "#/$defs/triState" },
        "scaledAlternativeCanBypassMajorityBy2033": { "$ref": "#/$defs/triState" }
      }
    },
    "workflowReplacement": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "applies", "customerOwnsCoreState", "workflowRebuildableByAgents",
        "vendorControlsRegulatedOrIrreversibleExecution",
        "vendorExecutionType", "vendorExecutionCoversMajorityCore",
        "workflowCoversMajorityCore",
        "majorityCustomReplacementEconomicallyPlausibleBy2033",
        "migrationComplexityPrimaryBarrier"
      ],
      "properties": {
        "applies": { "$ref": "#/$defs/triState" },
        "customerOwnsCoreState": { "$ref": "#/$defs/triState" },
        "workflowRebuildableByAgents": { "$ref": "#/$defs/triState" },
        "vendorControlsRegulatedOrIrreversibleExecution": { "$ref": "#/$defs/triState" },
        "vendorExecutionType": {
          "enum": [
            "none", "regulated_ledger_or_mandate", "money_movement", "security_enforcement",
            "compute_identity_control_plane", "physical_or_transaction_execution", "unproven"
          ]
        },
        "vendorExecutionCoversMajorityCore": { "$ref": "#/$defs/triState" },
        "workflowCoversMajorityCore": { "$ref": "#/$defs/triState" },
        "majorityCustomReplacementEconomicallyPlausibleBy2033": { "$ref": "#/$defs/triState" },
        "migrationComplexityPrimaryBarrier": { "$ref": "#/$defs/triState" }
      }
    },
    "serviceOperatorMechanics": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "applies", "customerBuysOutcomeNotTool", "companyOwnsInternalOperatingStack",
        "companyControlsStructuredOperationalData", "companyRetainsExecutionAccountability",
        "aiExpandsServiceCapacity", "serviceRoleCoversMajorityCore",
        "customerCanInternalizeMajorityBy2033"
      ],
      "properties": {
        "applies": { "$ref": "#/$defs/triState" },
        "customerBuysOutcomeNotTool": { "$ref": "#/$defs/triState" },
        "companyOwnsInternalOperatingStack": { "$ref": "#/$defs/triState" },
        "companyControlsStructuredOperationalData": { "$ref": "#/$defs/triState" },
        "companyRetainsExecutionAccountability": { "$ref": "#/$defs/triState" },
        "aiExpandsServiceCapacity": { "$ref": "#/$defs/triState" },
        "serviceRoleCoversMajorityCore": { "$ref": "#/$defs/triState" },
        "customerCanInternalizeMajorityBy2033": { "$ref": "#/$defs/triState" }
      }
    },
    "operationalControlPlaneMechanics": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "applies", "vendorProvidesCrossSystemStateModel", "vendorEnforcesPermissionsAndActions",
        "executionCoversMajorityCore", "agentsNeedCompanyRuntime",
        "customerCanReplicateAtEquivalentReliabilityBy2033",
        "hyperscalerCanBypassMajorityBy2033", "runtimeNecessityMechanism",
        "customerReplicationPath", "hyperscalerBypassPath"
      ],
      "properties": {
        "applies": { "$ref": "#/$defs/triState" },
        "vendorProvidesCrossSystemStateModel": { "$ref": "#/$defs/triState" },
        "vendorEnforcesPermissionsAndActions": { "$ref": "#/$defs/triState" },
        "executionCoversMajorityCore": { "$ref": "#/$defs/triState" },
        "agentsNeedCompanyRuntime": { "$ref": "#/$defs/triState" },
        "customerCanReplicateAtEquivalentReliabilityBy2033": { "$ref": "#/$defs/triState" },
        "hyperscalerCanBypassMajorityBy2033": { "$ref": "#/$defs/triState" },
        "runtimeNecessityMechanism": { "type": "string", "minLength": 1 },
        "customerReplicationPath": { "type": "string", "minLength": 1 },
        "hyperscalerBypassPath": { "type": "string", "minLength": 1 }
      }
    },
    "valueCapture": {
      "allOf": [
        { "$ref": "#/$defs/common" },
        {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "marketplaceMechanics", "workflowReplacement", "serviceOperatorMechanics",
            "operationalControlPlaneMechanics", "roleArchetype", "agentsNeedControlledAccess",
            "credibleMajorityBypass", "finalNeedPersists", "paidCompanyRolePersists",
            "roleCoversMajorityCore", "majorityAbsorptionWithinSevenYears",
            "companySpecificControl", "paymentMechanismPersists", "aiPriceCommoditization",
            "aiPriceCommoditizationCoversMajorityCore"
          ],
          "properties": {
            "reason": true,
            "adverseCase": true,
            "decisiveTrigger": true,
            "confidence": true,
            "marketplaceMechanics": { "$ref": "#/$defs/marketplaceMechanics" },
            "workflowReplacement": { "$ref": "#/$defs/workflowReplacement" },
            "serviceOperatorMechanics": { "$ref": "#/$defs/serviceOperatorMechanics" },
            "operationalControlPlaneMechanics": { "$ref": "#/$defs/operationalControlPlaneMechanics" },
            "roleArchetype": {
              "enum": [
                "weak_digital_interface", "authoritative_system",
                "controlled_marketplace_liquidity", "transaction_or_asset_operator",
                "physical_product_operator", "regulated_operator",
                "proprietary_stack_operator", "brand_product_operator",
                "vertical_service_operator", "other", "unproven"
              ]
            },
            "agentsNeedControlledAccess": { "$ref": "#/$defs/triState" },
            "credibleMajorityBypass": { "$ref": "#/$defs/triState" },
            "finalNeedPersists": { "$ref": "#/$defs/triState" },
            "paidCompanyRolePersists": { "$ref": "#/$defs/triState" },
            "roleCoversMajorityCore": { "$ref": "#/$defs/triState" },
            "majorityAbsorptionWithinSevenYears": { "$ref": "#/$defs/triState" },
            "companySpecificControl": { "$ref": "#/$defs/triState" },
            "paymentMechanismPersists": { "$ref": "#/$defs/triState" },
            "aiPriceCommoditization": { "$ref": "#/$defs/triState" },
            "aiPriceCommoditizationCoversMajorityCore": { "$ref": "#/$defs/triState" }
          }
        }
      ]
    },
    "transition": {
      "allOf": [
        { "$ref": "#/$defs/common" },
        {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "futureAdaptationContract", "adaptationLeversSurviveScenario",
            "coreReconfigurableWithinScenario", "adaptationLeadTimeFits",
            "legacyConstraintManageable", "futureDifferentiatedAdaptationContract",
            "adaptationAdvantageType", "companySpecificAdaptationLevers",
            "adaptationMechanismCoversMajorityCore", "competitorsCanAccessSameLevers"
          ],
          "properties": {
            "reason": true,
            "adverseCase": true,
            "decisiveTrigger": true,
            "confidence": true,
            "futureAdaptationContract": { "const": true },
            "futureDifferentiatedAdaptationContract": { "const": true },
            "adaptationLeversSurviveScenario": { "$ref": "#/$defs/triState" },
            "coreReconfigurableWithinScenario": { "$ref": "#/$defs/triState" },
            "adaptationLeadTimeFits": { "$ref": "#/$defs/triState" },
            "legacyConstraintManageable": { "$ref": "#/$defs/triState" },
            "adaptationAdvantageType": {
              "enum": [
                "proprietary_internal_tooling_and_data", "modular_physical_architecture",
                "regulated_learning_system", "distribution_feedback_loop", "none", "unproven"
              ]
            },
            "companySpecificAdaptationLevers": { "$ref": "#/$defs/triState" },
            "adaptationMechanismCoversMajorityCore": { "$ref": "#/$defs/triState" },
            "competitorsCanAccessSameLevers": { "$ref": "#/$defs/triState" }
          }
        }
      ]
    }
  }
}
