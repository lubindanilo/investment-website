{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "installCommand": "pnpm install --frozen-lockfile --config.confirmModulesPurge=false",
  "buildCommand": "pnpm build:vercel",
  "outputDirectory": "apps/web/dist",
  "framework": null,
  "functions": {
    "api/[...all].ts": {
      "maxDuration": 60,
      "memory": 1024
    }
  },
  "rewrites": [
    { "source": "/sitemap.xml", "destination": "/api/[...all]" },
    { "source": "/health", "destination": "/api/[...all]" },
    { "source": "/api/(.*)", "destination": "/api/[...all]" },
    {
      "source": "/analyse/:ticker",
      "has": [
        {
          "type": "header",
          "key": "user-agent",
          "value": "(?i).*(googlebot|bingbot|google-inspectiontool|slurp|duckduckbot|baiduspider|yandexbot|sogou|exabot|facebot|facebookexternalhit|twitterbot|linkedinbot|whatsapp|telegrambot|discordbot|applebot|petalbot|ahrefsbot|semrushbot|mj12bot|dotbot|chatgpt-user|gptbot|claudebot|perplexitybot|google-extended).*"
        }
      ],
      "destination": "/api/[...all]"
    },
    {
      "source": "/blog/:slug",
      "has": [
        {
          "type": "header",
          "key": "user-agent",
          "value": "(?i).*(googlebot|bingbot|google-inspectiontool|slurp|duckduckbot|baiduspider|yandexbot|sogou|exabot|facebot|facebookexternalhit|twitterbot|linkedinbot|whatsapp|telegrambot|discordbot|applebot|petalbot|ahrefsbot|semrushbot|mj12bot|dotbot|chatgpt-user|gptbot|claudebot|perplexitybot|google-extended).*"
        }
      ],
      "destination": "/api/[...all]"
    },
    { "source": "/(.*)", "destination": "/index.html" }
  ],
  "redirects": [
    {
      "source": "/(.*)",
      "has": [{ "type": "host", "value": "www.lubin-investment.com" }],
      "destination": "https://lubin-investment.com/$1",
      "permanent": true
    }
  ]
}
