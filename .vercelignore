# Local-only infra
docker-compose.yml
scripts/*
# …sauf les scripts exécutés pendant build:vercel (doivent être déployés).
# Forme `scripts/*` + négation : `scripts/` + négation ne marcherait pas (gitignore ne
# ré-inclut pas un fichier si son dossier parent est exclu).
!scripts/check-api-shared-imports.mjs
!scripts/check-articles-order.mjs
!scripts/migrate-vercel.mjs
cron/

# Tests + fixtures (jamais exécutés en prod Vercel)
**/test/
**/*.test.ts
**/*.spec.ts
**/vitest.config.*

# Build output (Vercel régénère)
**/dist/
**/.turbo/
**/.next/

# IDE + OS
.vscode/
.idea/
.DS_Store

# Secrets — déjà dans .gitignore mais double-ceinture
.env
.env.local
.env.*.local
